# Git commit-msg hook: validates that commit messages follow Conventional Commits format.
# Install: git config core.hooksPath path/to/vm2.DevOps/scripts/githooks

set -euo pipefail

# Allowed commit types — keep in sync with changelog/cliff.prerelease.toml commit_parsers
readonly -a allowed_types=(style build feat test fix refactor perf security doc docs chore revert remove ci devops)

# Read the commit message (first line only for format validation)
subject=$(head -1 "$1")

# Allow merge commits (generated by git)
if [[ "$subject" =~ ^(Merge|Revert)\  ]]; then
    exit 0
fi

# Build the type alternation: feat|fix|perf|...
types_pattern=$(IFS='|'; echo "${allowed_types[*]}")

# Conventional Commits: type[(scope)][!]: description
# The ! before : indicates a breaking change
readonly cc_regex="^(${types_pattern})(\(.+\))?!?: .+"

if [[ ! "$subject" =~ $cc_regex ]]; then
    {
        echo ""
        echo "ERROR: Commit message does not follow Conventional Commits format."
        echo ""
        echo "  Expected:  <type>[(scope)][!]: <description>"
        echo "  Types:     ${allowed_types[*]}"
        echo "  Examples:  feat: add new glob pattern"
        echo "             fix(parser): handle empty input"
        echo "             refactor!: rename public API method"
        echo ""
        echo "  Your message: $subject"
        echo ""
    } >&2
    exit 1
fi
